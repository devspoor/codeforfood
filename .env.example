# ===========================================
# CodeForFood Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# App URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_URL=http://localhost:3000/admin

# Paddle Billing
# Get these from sandbox.paddle.com (switch to paddle.com for production)
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=
NEXT_PUBLIC_PADDLE_ENV=sandbox

# Paddle Price IDs (create in Paddle Dashboard)
NEXT_PUBLIC_PADDLE_PRICE_ID_PRO=
NEXT_PUBLIC_PADDLE_PRICE_ID_UNLIMITED=
